        "fontWeight": { "$value": "{typography.fontWeight.bold}" },
        "color": { "$value": "{color.text.primary}" },
        "textTransform": { "$value": "uppercase" },
        "letterSpacing": { "$value": "{typography.letterSpacing.wider}" },
        "marginBottom": { "$value": "{spacing.2}" }
      },
      "error": {
        "border": { "$value": "2px solid #FF6B6B" },
        "message": { "color": "{color.semantic.error.text}", "fontSize": "{typography.fontSize.xs}" }
      }
    },

    "badge": {
      "$description": "Badge and tag component tokens. Badges in Neo-Brutalism are solid-filled, thick-bordered, uppercase labels.",

      "border": { "$value": "2px solid #000000" },
      "radius": { "$value": "{border.radius.none}" },
      "fontWeight": { "$value": "{typography.fontWeight.bold}" },
      "fontSize": { "$value": "{typography.fontSize.xs}" },
      "textTransform": { "$value": "uppercase" },
      "letterSpacing": { "$value": "{typography.letterSpacing.widest}" },
      "paddingX": { "$value": "{spacing.2}" },
      "paddingY": { "$value": "{spacing.0.5}" },
      "shadow": { "$value": "{shadow.xs}", "$description": "2px 2px 0px #000. Badges have a micro shadow." },

      "variants": {
        "success": {
          "background": { "$value": "{color.accent.green}" },
          "color": { "$value": "{color.text.on-accent}" }
        },
        "warning": {
          "background": { "$value": "{color.accent.orange}" },
          "color": { "$value": "{color.text.on-accent}" }
        },
        "error": {
          "background": { "$value": "{color.accent.coral}" },
          "color": { "$value": "{color.text.on-accent}" }
        },
        "info": {
          "background": { "$value": "{color.accent.blue}" },
          "color": { "$value": "{color.text.inverse}" }
        },
        "primary": {
          "background": { "$value": "{color.accent.yellow}" },
          "color": { "$value": "{color.text.on-accent}" }
        },
        "purple": {
          "background": { "$value": "{color.accent.purple}" },
          "color": { "$value": "{color.text.inverse}" }
        },
        "neutral": {
          "background": { "$value": "{color.background.muted}" },
          "color": { "$value": "{color.text.primary}" }
        },
        "outline": {
          "background": { "$value": "transparent" },
          "color": { "$value": "{color.text.primary}" }
        }
      }
    },

    "sidebar": {
      "$description": "Left navigation sidebar tokens. The sidebar is the structural anchor of the dashboard. Uses near-black background for stark contrast against the white main content area.",

      "background": { "$value": "{color.background.sidebar}", "$description": "#0A0A0A near-black." },
      "borderRight": { "$value": "3px solid #000000" },
      "width": { "$value": "256px", "$description": "16rem. Standard sidebar width." },
      "widthCollapsed": { "$value": "64px", "$description": "4rem. Icon-only collapsed state." },
      "paddingX": { "$value": "{spacing.4}" },
      "paddingY": { "$value": "{spacing.4}" },

      "logo": {
        "paddingX": { "$value": "{spacing.4}" },
        "paddingY": { "$value": "{spacing.5}" },
        "borderBottom": { "$value": "2px solid #2A2A2A" },
        "fontFamily": { "$value": "{typography.fontFamily.display}" },
        "fontSize": { "$value": "{typography.fontSize.xl}" },
        "fontWeight": { "$value": "{typography.fontWeight.extrabold}" },
        "color": { "$value": "{color.text.inverse}" }
      },

      "navItem": {
        "default": {
          "background": { "$value": "transparent" },
          "color": { "$value": "#A3A3A3", "$description": "Mid-grey text for inactive nav items." },
          "fontWeight": { "$value": "{typography.fontWeight.medium}" },
          "fontSize": { "$value": "{typography.fontSize.sm}" },
          "paddingX": { "$value": "{spacing.3}" },
          "paddingY": { "$value": "{spacing.2.5}" },
          "radius": { "$value": "{border.radius.none}" },
          "border": { "$value": "2px solid transparent" }
        },
        "hover": {
          "background": { "$value": "{color.background.sidebar-hover}" },
          "color": { "$value": "{color.text.inverse}" },
          "border": { "$value": "2px solid #3A3A3A" }
        },
        "active": {
          "background": { "$value": "{color.background.sidebar-active}", "$description": "Electric Yellow #FFE500." },
          "color": { "$value": "{color.text.on-sidebar-active}", "$description": "Black text on yellow." },
          "fontWeight": { "$value": "{typography.fontWeight.bold}" },
          "border": { "$value": "2px solid #000000" },
          "shadow": { "$value": "3px 3px 0px 0px #000000" }
        }
      },

      "section": {
        "labelColor": { "$value": "#4A4A4A" },
        "labelFontSize": { "$value": "{typography.fontSize.2xs}" },
        "labelFontWeight": { "$value": "{typography.fontWeight.bold}" },
        "labelTextTransform": { "$value": "uppercase" },
        "labelLetterSpacing": { "$value": "{typography.letterSpacing.widest}" },
        "labelPaddingX": { "$value": "{spacing.3}" },
        "labelPaddingY": { "$value": "{spacing.3}" },
        "borderTop": { "$value": "1px solid #2A2A2A" }
      }
    },

    "topbar": {
      "$description": "Top navigation bar / header tokens.",
      "background": { "$value": "{color.background.canvas}" },
      "borderBottom": { "$value": "3px solid #000000" },
      "height": { "$value": "64px" },
      "paddingX": { "$value": "{spacing.6}" },
      "shadow": { "$value": "0px 3px 0px 0px #000000", "$description": "Bottom-only offset shadow for the header bar." }
    },

    "table": {
      "$description": "Data table component tokens. Tables in Neo-Brutalism are grid-like and structured.",
      "borderCollapse": { "$value": "collapse" },
      "border": { "$value": "2px solid #000000" },
      "headerBackground": { "$value": "{color.black}" },
      "headerColor": { "$value": "{color.text.inverse}" },
      "headerFontWeight": { "$value": "{typography.fontWeight.bold}" },
      "headerFontSize": { "$value": "{typography.fontSize.xs}" },
      "headerTextTransform": { "$value": "uppercase" },
      "headerLetterSpacing": { "$value": "{typography.letterSpacing.wider}" },
      "headerPaddingX": { "$value": "{spacing.4}" },
      "headerPaddingY": { "$value": "{spacing.3}" },
      "cellBorder": { "$value": "1px solid #000000" },
      "cellPaddingX": { "$value": "{spacing.4}" },
      "cellPaddingY": { "$value": "{spacing.3}" },
      "rowOdd": { "$value": "{color.background.canvas}" },
      "rowEven": { "$value": "{color.background.subtle}" },
      "rowHover": { "$value": "{color.accent.yellow}", "$description": "Yellow highlight on row hover — bold Neo-Brutalism table interaction." }
    },

    "modal": {
      "$description": "Modal/dialog overlay tokens.",
      "background": { "$value": "{color.background.canvas}" },
      "border": { "$value": "3px solid #000000" },
      "radius": { "$value": "{border.radius.none}" },
      "shadow": { "$value": "{shadow.2xl}", "$description": "12px 12px 0px #000 — modals must feel elevated and commanding." },
      "overlay": { "$value": "rgba(0, 0, 0, 0.75)" },
      "paddingX": { "$value": "{spacing.8}" },
      "paddingY": { "$value": "{spacing.8}" },
      "maxWidth": {
        "sm": { "$value": "400px" },
        "md": { "$value": "560px" },
        "lg": { "$value": "720px" },
        "xl": { "$value": "960px" }
      }
    },

    "tooltip": {
      "$description": "Tooltip tokens.",
      "background": { "$value": "{color.black}" },
      "color": { "$value": "{color.text.inverse}" },
      "border": { "$value": "1.5px solid #000000" },
      "radius": { "$value": "{border.radius.none}" },
      "shadow": { "$value": "{shadow.xs}" },
      "paddingX": { "$value": "{spacing.3}" },
      "paddingY": { "$value": "{spacing.1.5}" },
      "fontSize": { "$value": "{typography.fontSize.xs}" },
      "fontWeight": { "$value": "{typography.fontWeight.medium}" }
    },

    "select": {
      "$description": "Select / dropdown tokens.",
      "background": { "$value": "{color.background.canvas}" },
      "border": { "$value": "2px solid #000000" },
      "radius": { "$value": "{border.radius.none}" },
      "shadow": { "$value": "{shadow.sm}" },
      "paddingX": { "$value": "{spacing.4}" },
      "paddingY": { "$value": "{spacing.3}" },
      "fontSize": { "$value": "{typography.fontSize.base}" },
      "fontWeight": { "$value": "{typography.fontWeight.medium}" },
      "dropdownBackground": { "$value": "{color.background.canvas}" },
      "dropdownBorder": { "$value": "2px solid #000000" },
      "dropdownShadow": { "$value": "{shadow.lg}" },
      "optionHoverBackground": { "$value": "{color.accent.yellow}" }
    },

    "kpiCard": {
      "$description": "KPI metric card — the primary data display card in an analytics dashboard.",
      "background": { "$value": "{color.background.canvas}" },
      "border": { "$value": "3px solid #000000" },
      "radius": { "$value": "{border.radius.none}" },
      "shadow": { "$value": "{shadow.xl}", "$description": "8px 8px 0px #000 — KPI cards have maximum elevation." },
      "padding": { "$value": "{spacing.6}" },
      "valueFont": { "$value": "{typography.fontFamily.mono}" },
      "valueFontSize": { "$value": "{typography.fontSize.4xl}" },
      "valueFontWeight": { "$value": "{typography.fontWeight.extrabold}" },
      "labelFont": { "$value": "{typography.fontFamily.body}" },
      "labelFontSize": { "$value": "{typography.fontSize.xs}" },
      "labelFontWeight": { "$value": "{typography.fontWeight.bold}" },
      "labelTextTransform": { "$value": "uppercase" },
      "labelLetterSpacing": { "$value": "{typography.letterSpacing.wider}" },
      "labelColor": { "$value": "{color.text.secondary}" },
      "accentBar": {
        "$description": "Colored top-border accent strip on KPI cards — 4px solid accent color.",
        "height": { "$value": "4px" },
        "yellow": { "$value": "{color.accent.yellow}" },
        "green": { "$value": "{color.accent.green}" },
        "blue": { "$value": "{color.accent.blue}" },
        "coral": { "$value": "{color.accent.coral}" }
      }
    },

    "alert": {
      "$description": "Alert/notification banner tokens.",
      "border": { "$value": "2px solid #000000" },
      "radius": { "$value": "{border.radius.none}" },
      "shadow": { "$value": "{shadow.sm}" },
      "paddingX": { "$value": "{spacing.4}" },
      "paddingY": { "$value": "{spacing.4}" },
      "fontSize": { "$value": "{typography.fontSize.sm}" },
      "fontWeight": { "$value": "{typography.fontWeight.medium}" },
      "variants": {
        "success": { "background": "{color.accent.green}", "borderLeft": "4px solid #000000" },
        "warning": { "background": "{color.accent.orange}", "borderLeft": "4px solid #000000" },
        "error": { "background": "{color.accent.coral}", "borderLeft": "4px solid #000000" },
        "info": { "background": "{color.accent.blue}", "borderLeft": "4px solid #000000" }
      }
    },

    "tabs": {
